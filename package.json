{
  "name": "backlog-wiki-sync",
  "version": "0.1.0",
  "description": "Backlog Wiki と Git リポジトリ間で Markdown ファイルを双方向同期する CLI ツール",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "backlog-wiki-sync": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goda-kazuki/backlog-wiki-git.git"
  },
  "keywords": [
    "backlog",
    "wiki",
    "sync",
    "git",
    "markdown"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/goda-kazuki/backlog-wiki-git/issues"
  },
  "homepage": "https://github.com/goda-kazuki/backlog-wiki-git#readme",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
